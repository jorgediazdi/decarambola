# Supabase (obligatorio): service role para leer club_obs_config, overlay_state, escribir obs_logs
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# clubs.codigo del club donde corre este Mac (mismo criterio que profiles.club_id)
DECA_CLUB_ID=MVIP-001

# URL base del overlay (sin barra final)
OVERLAY_BASE_URL=https://decarambola.com

# Stream key del canal centralizado DeCarambola (perfil de transmisión en OBS / RTMP)
DECA_YT_STREAM_KEY=

# Opcional: título en YouTube Data API (OAuth); ver README
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=
# DECA_YOUTUBE_LIVE_BROADCAST_ID=
