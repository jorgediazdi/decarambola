# Copiar a .env (no subir .env a git)
# Valores de ejemplo — reemplazar por los de tu proyecto Supabase.

SUPABASE_URL=https://xxxx.supabase.co
# Para node check_club.js: con ANON alcanza si RLS permite SELECT en clubs
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Opcional (solo en tu PC, nunca en frontend): si ANON no lee por RLS
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Si usás nombres tipo Next.js:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
